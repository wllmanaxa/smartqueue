# Copy these into Render → Web Service → Environment
# Use double underscores for nested .NET configuration keys.

ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_FORWARDEDHEADERS_ENABLED=true
ConnectionStrings__DefaultConnection=Host=YOUR_NEON_HOST;Port=5432;Database=YOUR_DB;Username=YOUR_USER;Password=YOUR_PASSWORD;SSL Mode=Require;Trust Server Certificate=true
Jwt__Key=GENERATE_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARACTERS
Jwt__Issuer=SmartQueue
Jwt__Audience=SmartQueueClients
Cors__AllowedOrigins=https://your-app.vercel.app
Features__EnableSwagger=false
