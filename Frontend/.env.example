# --- Local development ---
# API base must include version segment (/api/v1.0)
VITE_API_BASE_URL=https://localhost:7159/api/v1.0

# Optional: Vite dev-server proxy target (when using /api proxy without VITE_API_BASE_URL)
VITE_DEV_API_PROXY=https://localhost:7159

# --- Vercel production (set in Vercel Project → Settings → Environment Variables) ---
